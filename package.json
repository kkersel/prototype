{
  "name": "terminal-prototyper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Figma-подобный сборщик прототипов для тестирования на терминалах (Android/Chrome) с тепловыми картами",
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm:server\" \"npm:client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.19.2",
    "multer": "^2.0.1",
    "nanoid": "^5.0.7",
    "peerjs": "^1.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  }
}
